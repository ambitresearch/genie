# ── Dependencies ──────────────────────────────────────────
node_modules/
package-lock.json

# ── Build output ──────────────────────────────────────────
dist/
*.tsbuildinfo
coverage/

# ── genie runtime state (GENIE_HOME default; plan grants, etc.) ──
# Generated at runtime by the MCP server (e.g. `plan`'s persisted
# planId JSON snapshots). Never source, never shipped.
/.genie/

# ── Private session memory (not part of the project) ──────
.remember/

# ── Claude Code local config (machine-specific) ───────────
.claude/

# ── Scratch / lab files (kept locally for reference, not shipped) ──
docs/designs/**/_*.html

# ── Deliverables junk drawer (unrelated homelab/plugin work) ──
# NOTE: this folder is NOT genie content — it's staging cruft from
# other tasks. The one genie artifact (skybridge research) has been
# moved to docs/research-artifacts/. Keep the whole folder ignored.
docs/.deliverables/

# ── OS / editor noise ─────────────────────────────────────
.DS_Store
*.swp
*~
.idea/
.vscode/

# ── Secrets (belt-and-suspenders; none currently in repo) ──
.env
.env.*
*.local
**/shellprivatevars
.gstack/
.goals
.hallmark
