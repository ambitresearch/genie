# genie server — environment variables
#
# Copy to `.env` and fill in real values. `.env` is gitignored — never commit
# actual secrets. See packages/server/src/config/secrets.ts (DRO-275 / M5-03)
# for the source of truth on which vars are secrets, required-ness, and
# minimum length. Every var below is read from the environment only (or, in
# a container, from a `--secrets-from <path>` mounted secret file) — genie
# never hardcodes a secret or default endpoint. Mounted secret files must be
# owner-only (`chmod 600` or stricter); group/other permission bits are rejected.

# ── Required secrets ─────────────────────────────────────────────────────────

# API key for the operator-configured OpenAI-compatible LLM endpoint.
# Required. Must be at least 16 characters. No default.
GENIE_LLM_API_KEY=

# HS256 signing key for OAuth access/refresh tokens issued by the MCP HTTP
# server (M5-01/M5-02). Required. Must be at least 16 characters. No default.
OAUTH_HS256_KEY=

# ── Optional secrets ─────────────────────────────────────────────────────────

# API token for the git host store adapter (GitHub/Gitea/GitLab). Only
# required if GitHostStore is in use instead of the local filesystem store.
GENIE_GIT_TOKEN=

# Confidential OAuth client secret, if the deployment registers a
# confidential (non-public) client out of band instead of relying on DCR.
OAUTH_CLIENT_SECRET=

# ── Non-secret configuration ─────────────────────────────────────────────────

# Base URL of the operator-configured OpenAI-compatible chat-completions
# endpoint (e.g. a LiteLLM gateway, Ollama, vLLM). No default.
GENIE_LLM_BASE_URL=

# Per-request LLM timeout override, in milliseconds. Default: 120000.
GENIE_LLM_REQUEST_TIMEOUT_MS=

# MCP transport: "stdio" or "http". Default: auto-detected by TTY.
MCP_TRANSPORT=

# Preview reachability: "local" or "remote".
GENIE_PREVIEW_LOCALITY=

# Directory where kit tools read/write UI kits. Default: .genie/kits.
GENIE_KITS_ROOT=

# Directory where create_project writes project roots.
GENIE_PROJECTS_ROOT=

# genie's home directory for local state (plans, etc). Default: ~/.genie.
GENIE_HOME=

# Plan TTL override, in milliseconds. Default: 3600000 (1 hour).
GENIE_PLAN_TTL=

# Maximum retries for transient/rate-limited LLM requests. Default: 3.
GENIE_LLM_RETRY_MAX=

# Public absolute http(s) origin used for remote embedded preview URLs.
# Required only when remote previews cannot use the local viewer.
GENIE_PREVIEWS_BASE_URL=

# Set to any truthy value to prevent local preview commands opening a browser.
GENIE_PREVIEW_NO_OPEN=

# Directory where validation reports are written. Default: .genie/reports.
GENIE_REPORTS_DIR=

# Maximum decoded bytes accepted by one write_files call. Default: 16777216.
GENIE_WRITE_BYTE_CAP=

# Set to 1 to use polling instead of native filesystem watch events.
GENIE_WATCH_USE_POLLING=

# Attribution recorded in sync anchors. Default: genie.
GENIE_BY=
