# genie server — environment variables (M5-03 / DRO-275)
#
# Copy to `.env` (or set these in your process manager / container) and fill
# in real values. Never commit a `.env` with real secrets — this file is the
# checked-in template only.

# ─── LLM endpoint (required) ────────────────────────────────────────────────
# Base URL of an OpenAI-compatible chat-completions endpoint. LiteLLM is the
# reference gateway; Ollama / OpenAI / vLLM / any compatible endpoint work.
GENIE_LLM_BASE_URL=
# API key for the endpoint above. Must be at least 16 characters.
GENIE_LLM_API_KEY=
# Optional per-request timeout override in milliseconds (default: 120000).
GENIE_LLM_REQUEST_TIMEOUT_MS=

# ─── Auth (optional, feature-gated) ─────────────────────────────────────────
# HS256 signing key for OAuth-issued tokens, if OAuth is enabled.
OAUTH_HS256_KEY=
# Client secret for the configured OAuth client, if OAuth is enabled.
OAUTH_CLIENT_SECRET=
# Set to "true" to require a Bearer token on every request (see auth/bearer.ts).
GENIE_REQUIRE_BEARER_AUTH=

# ─── Git host (optional, only for the GitHostStore adapter) ────────────────
# API token for the configured git host (Gitea/GitHub/GitLab). Required only
# when genie is configured to use GitHostStore instead of LocalFsStore.
GENIE_GIT_TOKEN=

# ─── Filesystem / storage paths ─────────────────────────────────────────────
# Root directory for genie's local state (plans, kits, projects, auth tokens).
# Defaults to ~/.genie.
GENIE_HOME=
# Directory where kit tools read/write UI kits. Defaults to <cwd>/.genie/kits.
GENIE_KITS_ROOT=
# Directory where create_project writes project roots.
GENIE_PROJECTS_ROOT=
# Directory where validate writes its report artifacts.
GENIE_REPORTS_DIR=
# Base URL used to construct externally-reachable preview links.
GENIE_PREVIEWS_BASE_URL=
# Plan TTL override in milliseconds (default: 1 hour).
GENIE_PLAN_TTL=

# ─── Transport ───────────────────────────────────────────────────────────────
# "stdio" or "http". Defaults to auto-detect by TTY.
MCP_TRANSPORT=
# "local" or "remote" — how previews should describe their own reachability.
GENIE_PREVIEW_LOCALITY=

# ─── Attribution ─────────────────────────────────────────────────────────────
# Free-text "by" attribution stamped on generated artifacts.
GENIE_BY=

# ─── Secrets from a mounted file (containers) ───────────────────────────────
# Instead of (or in addition to) the env vars above, you can pass
# `--secrets-from <path>` on the CLI to have genie merge KEY=value lines from
# a mounted file (e.g. a Docker/Kubernetes secret) into its environment at
# startup. Values already set via a real env var always take precedence.
