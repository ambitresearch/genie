{
  "name": "@genie/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "genie MCP server — harness-agnostic AI UI-component generation.",
  "bin": {
    "genie": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx watch src/cli.ts",
    "start": "node dist/cli.js",
    "build": "tsc -p tsconfig.json && node scripts/emit-component-schema.mjs && node scripts/copy-prompts.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ajv": "^8.20.0",
    "diff": "^8.0.2",
    "micromatch": "^4.0.8",
    "mime-types": "^3.0.2",
    "openai": "^6.45.0",
    "prom-client": "^15.1.3",
    "zod": "^4.4.3"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "MIT",
  "author": "Roshan Gautam",
  "devDependencies": {
    "@types/json-schema": "^7.0.15",
    "@types/micromatch": "^4.0.10",
    "@types/mime-types": "^3.0.1",
    "json-schema-to-ts": "^3.1.1",
    "yaml": "^2.9.0"
  }
}
