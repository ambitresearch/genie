{
  "name": "@genie/server",
  "version": "1.1.0",
  "type": "module",
  "description": "genie MCP server — harness-agnostic AI UI-component generation.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/roshangautam/genie.git",
    "directory": "packages/server"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "bin": {
    "genie": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx watch src/cli.ts",
    "start": "node dist/cli.js",
    "build": "tsc -p tsconfig.json && node scripts/emit-component-schema.mjs && node scripts/copy-prompts.mjs && node scripts/copy-viewer-assets.mjs && node scripts/verify-packaged-viewer.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@vue/compiler-sfc": "^3.5.0",
    "ajv": "^8.20.0",
    "blockhash-core": "^0.1.0",
    "chokidar": "^3.6.0",
    "diff": "^8.0.2",
    "esbuild": "^0.28.1",
    "micromatch": "^4.0.8",
    "mime-types": "^3.0.2",
    "openai": "^6.45.0",
    "parse5": "^7.3.0",
    "pngjs": "^7.0.0",
    "prom-client": "^15.1.3",
    "ts-morph": "^28.0.0",
    "zod": "^4.4.3"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "MIT",
  "author": "Roshan Gautam",
  "devDependencies": {
    "@genie/viewer": "workspace:*",
    "@types/jsdom": "^21.1.7",
    "@types/json-schema": "^7.0.15",
    "@types/micromatch": "^4.0.10",
    "@types/mime-types": "^3.0.1",
    "@types/pngjs": "^6.0.5",
    "jsdom": "^25.0.1",
    "json-schema-to-ts": "^3.1.1",
    "playwright": "^1.58.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vue": "^3.5.39",
    "yaml": "^2.9.0"
  }
}
