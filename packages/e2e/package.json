{
  "name": "@genie/e2e",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "genie end-to-end + harness smoke tests. Hosts the M1 19-tool conformance suite (M1-14 / DRO-318).",
  "scripts": {
    "build": "echo \"@genie/e2e: test-only package, nothing to build\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:e2e:viewer": "vitest run --root ../.. --config vitest.config.ts packages/e2e/test/m4-viewer.test.ts",
    "test:e2e:copilot": "vitest run --root ../.. --config vitest.config.ts packages/e2e/test/m5-smoke-copilot.test.ts",
    "test:e2e:codex": "vitest run --root ../.. --config vitest.config.ts packages/e2e/test/m5-smoke-codex.test.ts"
  },
  "license": "MIT",
  "author": "Roshan Gautam",
  "dependencies": {
    "@genie/server": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@genie/viewer": "workspace:*",
    "@types/node": "^26.0.0",
    "playwright": "^1.61.1",
    "testcontainers": "^12.0.4",
    "vite": "^8.1.3"
  },
  "optionalDependencies": {
    "@cline/cli-darwin-arm64": "3.0.42",
    "@cline/cli-darwin-x64": "3.0.42",
    "@cline/cli-linux-arm64": "3.0.42",
    "@cline/cli-linux-x64": "3.0.42",
    "@cline/cli-windows-arm64": "3.0.42",
    "@cline/cli-windows-x64": "3.0.42"
  }
}
